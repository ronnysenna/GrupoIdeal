# Copie para .env e ajuste. Usado por Next (apps/web) e por docker compose.

# PostgreSQL (app + `docker compose` — senha do serviço `postgres` e URL do `web`)
POSTGRES_PASSWORD=defina_uma_senha_forte

# String usada pelo Prisma no app local (porta 5432 exposta no host)
# Local com compose:
DATABASE_URL=postgresql://ideal:defina_uma_senha_forte@127.0.0.1:5432/idealnet?schema=public
# Dentro da rede Docker o compose injeta: postgresql://ideal:...@postgres:5432/idealnet?schema=public

# Público (URL do site, para metadados e links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# E-mail (Nodemailer — envio de notificação de novo cadastro)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
MAIL_TO=

# pgAdmin (docker compose, serviço `pgadmin`, porta 5050)
PGADMIN_EMAIL=admin@local.dev
PGADMIN_PASSWORD=defina_uma_senha_forte

# Rate limit (POST /api/cadastro) — in-memory por instância; desligar em dev se precisar
# RATE_LIMIT_DISABLED=1
# RATE_LIMIT_CADASTRO_MAX=8
# RATE_LIMIT_CADASTRO_WINDOW_MS=60000
# Opcional: Upstash (limite partilhado entre réplicas). Se definido, substitui o in-memory.
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# Listagem admin (GET /api/admin/cadastros) — 503 se vazio. Cabeçalho: X-Admin-Key: <chave> ou Authorization: Bearer <chave>
# ADMIN_API_KEY=

# E2E Playwright: teste de integração (POST /api/cadastro real com Prisma) — exige `pnpm --filter @ideal/db exec prisma migrate deploy` e DATABASE_URL
# E2E_INTEGRATION=1
