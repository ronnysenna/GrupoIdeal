{
  "name": "grupoideal",
  "private": true,
  "description": "Grupo Ideal — monorepo (Next.js, pacotes compartilhados, legado PHP/HTML)",
  "packageManager": "pnpm@10.12.2",
  "scripts": {
    "postinstall": "pnpm run db:generate",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:generate": "pnpm --filter @ideal/db run db:generate",
    "db:push": "pnpm --filter @ideal/db exec prisma db push",
    "db:migrate": "pnpm --filter @ideal/db exec prisma migrate dev",
    "db:migrate:deploy": "pnpm --filter @ideal/db run db:migrate:deploy",
    "test": "turbo run test"
  },
  "devDependencies": {
    "turbo": "^2.5.0"
  },
  "engines": {
    "node": ">=20"
  }
}
