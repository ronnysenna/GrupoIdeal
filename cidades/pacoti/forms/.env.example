# =================================================================
# CONFIGURAÇÕES IDEAL NET PACOTI - FORMULÁRIO DE CADASTRO
# =================================================================

# Banco de Dados
DB_HOST=localhost
DB_USER=seu_usuario_mysql
DB_PASSWORD=sua_senha_mysql
DB_NAME=idealnet_pacoti_db

# SMTP - Envio de E-mails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=seu_email@gmail.com
SMTP_PASSWORD=sua_senha_ou_app_password

# Destinatário dos E-mails
MAIL_TO=macicoidealnet@gmail.com

# URL de Redirecionamento após Cadastro
REDIRECT_URL=https://provedoridealnet.com/

# =================================================================
# INSTRUÇÕES:
# 1. Copie este arquivo para .env (sem o .example)
# 2. Preencha com suas credenciais reais
# 3. NUNCA faça commit do arquivo .env no Git
